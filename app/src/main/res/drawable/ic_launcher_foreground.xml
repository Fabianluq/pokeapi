<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground — Pokéball
    Canvas: 108 x 108 dp (standard adaptive icon)
    Safe zone: 18dp inset on all sides → content in 72x72 area centered at (54,54)
    Pokéball circle: center (54,54), radius 32
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        ── Layer 1: Clipped Pokéball body ──────────────────────────────────
        All fill elements are clipped to the outer circle so nothing bleeds
        outside the ball edge.
        Circle: M54,22 A32,32 0 1,1 54,86 A32,32 0 1,1 54,22
    -->
    <group>
        <clip-path
            android:pathData="M54,22 A32,32 0 1,1 53.999,22z" />

        <!-- Red top half -->
        <path
            android:fillColor="#E8283C"
            android:pathData="M0,0 L108,0 L108,54 L0,54 Z" />

        <!-- White bottom half -->
        <path
            android:fillColor="#F0F0F0"
            android:pathData="M0,54 L108,54 L108,108 L0,108 Z" />

        <!-- Dark middle band -->
        <path
            android:fillColor="#1A1A2E"
            android:pathData="M0,49 L108,49 L108,59 L0,59 Z" />

        <!-- Subtle red shine on top half -->
        <path
            android:fillColor="#FF4D5E"
            android:pathData="M54,22 A32,32 0 0,1 86,40 L22,40 A32,32 0 0,1 54,22 Z" />
    </group>

    <!--
        ── Layer 2: Outer circle stroke ────────────────────────────────────
    -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1A1A2E"
        android:strokeWidth="3.5"
        android:pathData="M54,22 A32,32 0 1,1 53.999,22z" />

    <!--
        ── Layer 3: Center button ───────────────────────────────────────────
        Outer ring (dark), white fill, inner highlight dot
    -->
    <!-- Dark ring -->
    <path
        android:fillColor="#1A1A2E"
        android:pathData="M54,43 A11,11 0 1,1 53.999,43z" />

    <!-- White fill -->
    <path
        android:fillColor="#F0F0F0"
        android:pathData="M54,46 A8,8 0 1,1 53.999,46z" />

    <!-- Specular highlight (small white arc, top-left of button) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M50,51 A5,5 0 0,1 54,46 A5,5 0 0,0 50,51z" />

    <!--
        ── Layer 4: Decorative dots (subtle Pokémon style) ──────────────────
        Two small dots on each side of the center band
    -->
    <!-- Left dot -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.25"
        android:pathData="M30,51 A3.5,3.5 0 1,1 29.999,51z" />

    <!-- Right dot -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.25"
        android:pathData="M78,51 A3.5,3.5 0 1,1 77.999,51z" />

</vector>